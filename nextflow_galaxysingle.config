/*
========================================================================================
    Configuración — Pipeline ABRicate equivalente al Workflow Galaxy "Trabajo ADO"
    Universidad de Murcia — Máster en Bioinformática 2025-2026
========================================================================================
*/

nextflow.enable.dsl=2

profiles {

    // Perfil para el cluster ECK con SLURM
    cluster {
        process.executor   = 'slurm'
        process.queue      = 'eck-q'
        process.cpus       = 2
        process.memory     = '4 GB'
        process.time       = '1h'
    }

    // Perfil local para pruebas
    local {
        process.executor = 'local'
        process.cpus     = 2
        process.memory   = '4 GB'
    }
}

// Configuración específica por proceso
process {
    withName: 'FASTQC' {
        cpus   = 2
        memory = '4 GB'
        time   = '30m'
    }
    withName: 'ABRICATE_LIST' {
        cpus   = 1
        memory = '1 GB'
        time   = '5m'
    }
    withName: 'ABRICATE_CARD|ABRICATE_VFDB|ABRICATE_RESFINDER' {
        cpus   = 2
        memory = '4 GB'
        time   = '30m'
    }
    withName: 'ABRICATE_SUMMARY' {
        cpus   = 1
        memory = '2 GB'
        time   = '10m'
    }
}

// Directorio de trabajo temporal
workDir = '/home/alumno13/TareaADO/nextflow_work'

// Informes de ejecución
report {
    enabled = true
    file    = '/home/alumno13/TareaADO/nextflow_abricate/pipeline_report.html'
}

timeline {
    enabled = true
    file    = '/home/alumno13/TareaADO/nextflow_abricate/pipeline_timeline.html'
}

dag {
    enabled = true
    file    = '/home/alumno13/TareaADO/nextflow_abricate/pipeline_dag.html'
}
